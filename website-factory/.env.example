# Website Factory Pipeline — copy to .env and fill in real values.
# .env is gitignored; this example file is committed.

# Gemini Image API (Nano Banana 2). Used by tools/generate-hero.py at Stage 9.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image-preview

# Apify API. Used by tools/apify-scrape.py at Stages 2 + 4 + 7.5.
APIFY_API_TOKEN=
APIFY_PER_CLIENT_USD_CAP=2.00

# Anthropic API. Used by tools/old-site-resonance.py at Stage 7.5 for the
# Claude Vision call that returns voice_description + photo_style_note +
# theme_mode_recommendation. Stage 7.5 runs without this key (falls back to
# brightness-based theme mode), so this is optional.
ANTHROPIC_API_KEY=
