# AIW 2.0 Stack — environment variables
# Copy this file to .env.local and fill in the keys.
# .env.local is gitignored. Never commit secrets.

# ----- Anthropic (Claude API) -----
# Sign up at https://console.anthropic.com (first $5 free)
ANTHROPIC_API_KEY=

# ----- Apify (niche research scraping) -----
# Sign up at https://apify.com/sign-up ($5 free credit)
APIFY_TOKEN=

# ----- Supabase (content engine database) -----
# Create a project at https://supabase.com/dashboard
# Free tier covers a single student project.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- AssemblyAI (audio transcription, optional) -----
# Sign up at https://www.assemblyai.com ($50 free credit)
ASSEMBLYAI_API_KEY=

# ----- Vercel (deploy CLI uses vercel login, no key needed here) -----
# Install: npm i -g vercel
# Login: vercel login

# ----- GitHub (deploy CLI uses gh auth login, no key needed here) -----
# Install: brew install gh (or platform equivalent)
# Login: gh auth login

# ----- Optional: Nano Banana / Gemini for hero image generation -----
# Used by the website factory if you build with hero images
GEMINI_API_KEY=
